{
  "rules": {
    ".read": false,
    ".write": false,
    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.hasChildren(['nome', 'lastSeen']) && newData.child('nome').isString() && newData.child('nome').val().length <= 100"
      }
    },
    "chat_geral": {
      ".read": "auth != null",
      "messages": {
        ".indexOn": ["timestamp"],
        "$messageId": {
          ".write": "auth != null && (!data.exists() || data.child('uid').val() == auth.uid || (!newData.exists() && data.child('timestamp').val() < (now - 86400000)))",
          ".validate": "newData.hasChildren(['uid', 'nome', 'texto', 'timestamp']) && newData.child('texto').isString() && newData.child('texto').val().length > 0 && newData.child('texto').val().length <= 500 && newData.child('uid').val() == auth.uid"
        }
      }
    }
  }
}
