{
    "hosting": {
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**",
            "**/*.exe",
            "**/*.bat",
            "**/*.sh",
            "**/*.cmd",
            "**/*.ps1",
            "**/*.dll",
            "**/ENGENHARIA_BOAS_PRATICAS.md",
