rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // FUNCTIONS
    // ========================================================================

    // Usuário autenticado no Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Dono do documento
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Perfil do usuário logado em users/{uid}
    function hasProfile() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Usuário com perfil ATIVO — camada real de segurança (plano Spark,
    // sem custom claims/Cloud Functions). Conta desativada perde todo acesso.
    function isActive() {
      return hasProfile() && myProfile().status == 'ATIVO';
    }

    // Admin: custom claim (legado) OU cargo ADMIN no perfil ativo
    function isAdmin() {
      return (isAuthenticated() && request.auth.token.admin == true)
        || (isActive() && myProfile().cargo == 'ADMIN');
    }

    // Cargos de liderança (validações e gestão)
    function isManager() {
      return isActive()
        && myProfile().cargo in ['ADMIN', 'DIRETOR', 'SUPERINTENDENTE', 'GERENTE', 'COORDENADOR'];
    }

    // Nível hierárquico de um cargo (espelha ROLE_HIERARCHY em notifications.js)
    function cargoLevel(cargo) {
      return cargo == 'ADMIN' ? 100
        : cargo == 'DIRETOR' ? 95
        : cargo == 'SUPERINTENDENTE' ? 90
        : cargo == 'GERENTE' ? 70
        : cargo == 'CONSULTOR' ? 60
        : cargo == 'COORDENADOR' ? 50
        : cargo == 'ANALISTA' ? 30
        : cargo == 'MONITOR' ? 10
        : 0;
    }

    // ========================================================================
    // USERS
    // ========================================================================

    match /users/{userId} {
      // Leitura: usuários ativos (listas, delegação, rankings) e o próprio
      // usuário (necessário no login, antes da checagem de status)
      allow read: if isActive() || isOwner(userId);
      // Criação: admin (painel ADM/importação) ou o próprio uid recém-criado
      allow create: if isAdmin() || isOwner(userId);
      // Atualização: admin controla tudo; o próprio usuário edita seu perfil,
      // mas NUNCA pode alterar o próprio cargo ou status (anti-escalação)
      allow update: if isAdmin()
        || (isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['cargo', 'status']));
      allow delete: if isAdmin();
    }

    // ========================================================================
    // PÁGINAS PÚBLICAS (sem login)
    // ========================================================================

    // Mural público de depoimentos (public-feedback.html envia sem login;
    // aprovação/moderação é interna).
    // Criação anônima é validada por shape: campos e tamanhos limitados,
    // e todo envio público nasce obrigatoriamente como não-aprovado.
    match /testimonials/{document} {
      allow read: if isAuthenticated();
      allow create: if isActive()
        || (
          request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 2000
          && request.resource.data.toName is string
          && request.resource.data.toName.size() <= 120
          && (!('fromName' in request.resource.data) || (request.resource.data.fromName is string && request.resource.data.fromName.size() <= 120))
          && (!('tags' in request.resource.data) || (request.resource.data.tags is list && request.resource.data.tags.size() <= 10))
          && request.resource.data.approved == false
          && request.resource.data.keys().hasOnly(['toName', 'message', 'fromName', 'tags', 'createdAt', 'origin', 'approved', 'public'])
        );
      allow update: if isActive();
      allow delete: if isAdmin();
    }

    // Changelog público (status.html)
    match /status_updates/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notificações: página pública cria apenas o aviso de novo feedback
    // (shape estrito e tamanhos limitados); leitura/gestão para ativos
    match /notifications/{notificationId} {
      allow create: if isActive()
        || (
          request.resource.data.titulo is string
          && request.resource.data.titulo.size() <= 200
          && request.resource.data.mensagem is string
          && request.resource.data.mensagem.size() <= 500
          && request.resource.data.referencia_tipo == 'testimonials'
          && request.resource.data.keys().hasOnly(['titulo', 'mensagem', 'destinatario_uid', 'lida', 'data', 'tipo', 'referencia_tipo'])
        );

      // Leitura restrita a quem a notificação é endereçada (uid, cargo,
      // broadcast 'ALL' ou hierarquia por destinatario_cargo) ou admin —
      // impede que qualquer ativo baixe notificações de outras pessoas.
      allow read, update, delete: if isActive() && (
        isAdmin()
        || resource.data.destinatario_uid == request.auth.uid
        || resource.data.destinatario_uid == 'ALL'
        || resource.data.destinatario_uid == myProfile().cargo
        || (resource.data.destinatario_cargo != null
            && cargoLevel(resource.data.destinatario_cargo) <= cargoLevel(myProfile().cargo))
      );
    }

    // ========================================================================
    // ADMINISTRAÇÃO E PERMISSÕES
    // ========================================================================

    match /module_permissions/{moduleId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    match /tool_permissions/{toolId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    match /logos/{logoId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // Auditoria: imutável — ninguém edita ou apaga logs
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ========================================================================
    // OPERAÇÃO (exige perfil ATIVO)
    // ========================================================================

    // Kanban: leitura/criação/edição para ativos; exclusão espelha o front-end
    // (kanban.js canDeleteTask): apenas ADMIN ou o criador da demanda
    match /tasks/{taskId} {
      allow read, create, update: if isActive();
      allow delete: if isAdmin() || (isActive() && resource.data.creatorUid == request.auth.uid);
    }
    match /deliveries/{deliveryId} { allow read, write: if isActive(); }
    match /entregas/{entregaId} { allow read, write: if isActive(); }
    match /reports/{reportId} { allow read, write: if isActive(); }

    match /vacations/{vacationId} { allow read, write: if isActive(); }
    match /vacation_requests/{requestId} { allow read, write: if isActive(); }

    match /daily_routines/{docId} { allow read, write: if isActive(); }
    match /rotina_checklist/{docId} { allow read, write: if isActive(); }
    match /rotinas_adm/{docId} { allow read, write: if isActive(); }

    match /feedback_requests/{document} { allow read, write: if isActive(); }

    // ========================================================================
    // CURSOS
    // ========================================================================

    match /courses/{courseId} {
      allow read: if isActive();
      allow write: if isManager();
    }

    match /course_progress/{progressId} { allow read, write: if isActive(); }
    match /user_courses/{docId} { allow read, write: if isActive(); }

    // ========================================================================
    // COMUNICAÇÃO
    // ========================================================================

    match /announcements/{avisoId} {
      allow read: if isActive();
      allow write: if isManager();
    }

    match /push_subscriptions/{subId} {
      allow read: if isAdmin() || isOwner(subId);
      allow write: if isOwner(subId) || isAdmin();
    }

    // ========================================================================
    // FÓRUM
    // ========================================================================

    match /forum_topics/{topicId} {
      allow read, create, update: if isActive();
      allow delete: if isAdmin() || (isActive() && resource.data.author_uid == request.auth.uid);

      match /replies/{replyId} {
        allow read, create, update: if isActive();
        allow delete: if isAdmin();
      }
    }

    match /forum_replies/{replyId} {
      allow read, create, update: if isActive();
      allow delete: if isAdmin() || (isActive() && resource.data.author_uid == request.auth.uid);
    }

    // ========================================================================
    // CENTRAL DE CHAMADOS (TICKETS)
    // ========================================================================

    match /tickets/{ticketId} {
      allow read: if isActive()
        && (resource.data.created_by == request.auth.uid || resource.data.assigned_to == request.auth.uid || isAdmin());
      allow create: if isActive() && request.resource.data.created_by == request.auth.uid;
      allow update: if isActive()
        && (resource.data.created_by == request.auth.uid || resource.data.assigned_to == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isActive() && resource.data.created_by == request.auth.uid);
    }

    // ========================================================================
    // PORTAL CORPORATIVO DE PAINÉIS HTML
    // ========================================================================

    // Aprovadores das análises (técnica/visual/segurança): COORDENADOR+
    function isPanelApprover() {
      return isActive()
        && myProfile().cargo in ['ADMIN', 'DIRETOR', 'SUPERINTENDENTE', 'GERENTE', 'CONSULTOR', 'COORDENADOR'];
    }

    // Gestão/governança (publicar, suspender, arquivar, rollback): GERENTE+
    function isPanelManager() {
      return isActive()
        && myProfile().cargo in ['ADMIN', 'DIRETOR', 'SUPERINTENDENTE', 'GERENTE'];
    }

    match /panels/{panelId} {
      allow read: if isActive();
      // Criação: qualquer ativo, sempre como dono e nunca já publicado
      allow create: if isActive()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status in ['RASCUNHO', 'EM_ANALISE'];
      // Atualização: gestão controla tudo; dono atualiza o próprio painel
      // MAS não pode se autopublicar; qualquer ativo só incrementa views
      allow update: if isPanelManager()
        || (isActive()
          && resource.data.ownerUid == request.auth.uid
          && !(request.resource.data.status == 'PUBLICADO' && resource.data.status != 'PUBLICADO'))
        || (isActive()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']));
      allow delete: if isAdmin();

      match /versions/{versionId} {
        allow read: if isActive();
        // Envio de versão: autor real da sessão, sempre em análise
        allow create: if isActive()
          && request.resource.data.submittedByUid == request.auth.uid
          && request.resource.data.status == 'EM_ANALISE';
        // Pareceres/publicação: aprovador que NÃO seja o dono do painel
        // (segregação autor × aprovador garantida no servidor)
        allow update: if (
            isPanelApprover()
            && get(/databases/$(database)/documents/panels/$(panelId)).data.ownerUid != request.auth.uid
          ) || isPanelManager() || isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /panel_favorites/{favId} {
      allow read: if isActive();
      allow create: if isActive() && request.resource.data.uid == request.auth.uid;
      allow delete: if isActive() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /panel_reports/{reportId} {
      allow read: if isActive();
      allow create: if isActive() && request.resource.data.uid == request.auth.uid;
      allow update: if isActive();
      allow delete: if isAdmin();
    }

    // ========================================================================
    // GAMIFICAÇÃO E ANALYTICS
    // ========================================================================

    match /analytics/{document=**} { allow read, write: if isActive(); }
    match /user_analytics/{docId} { allow read, write: if isActive(); }
    match /user_data/{docId} { allow read, write: if isActive(); }

    match /points/{docId} { allow read, write: if isActive(); }
    match /user_points/{userId} { allow read, write: if isActive(); }

    match /points_transactions/{transactionId} {
      allow read: if isActive();
      allow create: if isActive();
      allow update, delete: if isAdmin();
    }

    match /user_stats/{userId} { allow read, write: if isActive(); }
    match /user_achievements/{uid} { allow read, write: if isActive(); }

    match /achievements/{achievementId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // ========================================================================
    // DEFAULT DENY
    // ========================================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
